generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  avatar     String?
  isVerified Boolean @default(false)
  isDeleted  Boolean @default(false)

  provider   String? // google, github
  providerId String? // oauth id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reviews   Review[]
  comments  Comment[]
  likes     Like[]
  watchlist Watchlist[]
  payments  Payment[]
  // purchases Purchase[]

  subscriptions Subscription[]
}

//////////////////////////////////////////////////////
// MOVIE / SERIES
//////////////////////////////////////////////////////

model Movie {
  id          String @id @default(uuid())
  title       String
  description String
  releaseYear Int
  director    String

  streamingLink String?
  price         Float   @default(0)
  isPremium     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cast        String[] 
  language    String? 
  duration    Int? 
  ageRating   String? 
  country     String?
  trailerLink String? 
  thumbnail   String? 
  banner      String? 
  subtitles   String[] 
  awards      String[] 
  budget      Float? 
  boxOffice   Float? 
  status      String? 
  rating      Float? 

  reviews   Review[]
  watchlist Watchlist[]
  genres    MovieGenre[]
}

//////////////////////////////////////////////////////
// REVIEW
//////////////////////////////////////////////////////

model Review {
  id      String   @id @default(uuid())
  rating  Int      @default(0)
  content String
  tags    String[]
  spoiler Boolean  @default(false)

  status   ReviewStatus @default(PENDING)
  isEdited Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  movieId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  comments Comment[]
  likes    Like[]
}

//////////////////////////////////////////////////////
// COMMENT
//////////////////////////////////////////////////////

model Comment {
  id      String @id @default(uuid())
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean @default(false)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id])

  // Optional nested replies
  parentId String?
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentToComment")
}

//////////////////////////////////////////////////////
// LIKE
//////////////////////////////////////////////////////

model Like {
  id String @id @default(uuid())

  userId   String
  reviewId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  review Review @relation(fields: [reviewId], references: [id])

  @@unique([userId, reviewId]) // one like per user
}

//////////////////////////////////////////////////////
// WATCHLIST
//////////////////////////////////////////////////////

model Watchlist {
  id String @id @default(uuid())

  userId  String
  movieId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("id")
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  stripeEventId String?       @unique
  id            String        @id @default(uuid())
  amount        Float
  status        PaymentStatus @default(PENDING)
  provider      String
  method        String? // "stripe"
  transactionId String?       @unique

  createdAt DateTime @default(now())

  // relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
}


model Genre {
  id   String @id @default(uuid())
  name String @unique

  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([movieId, genreId])
}

model Subscription {
  id String @id @default(uuid())

  userId String
  planId String

  startDate DateTime @default(now())
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  payments Payment[]

  @@index([userId])
}

model SubscriptionPlan {
  id       String @id @default(uuid())
  name     String 
  price    Float
  duration Int 

  stripePriceId String? @unique 
  // optional but useful
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  subscriptions Subscription[]
}
