generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AccessType {
  FREE
  RENT
  PURCHASE
  SUBSCRIPTION
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  avatar     String?
  isVerified Boolean @default(false)
  isDeleted  Boolean @default(false)

  provider   String? // google, github
  providerId String? // oauth id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reviews   Review[]
  comments  Comment[]
  likes     Like[]
  watchlist Watchlist[]
  payments  Payment[]
  purchases Purchase[]
}

//////////////////////////////////////////////////////
// MOVIE / SERIES
//////////////////////////////////////////////////////

model Movie {
  id          String @id @default(uuid())
  title       String
  description String
  releaseYear Int
  director    String

  streamingLink String?
  price         Float   @default(0)
  isPremium     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Additional professional fields
  cast        String[] // ["Leonardo DiCaprio", "Joseph Gordon-Levitt"]
  language    String? // e.g., "English"
  duration    Int? // in minutes
  ageRating   String? // e.g., "PG-13", "R"
  country     String? // production country
  trailerLink String? // YouTube/Vimeo trailer
  thumbnail   String? // Poster image URL
  banner      String? // Banner image URL
  subtitles   String[] // ["en", "es", "fr"]
  awards      String[] // ["Oscar 2011", "Golden Globe 2010"]
  budget      Float? // production budget
  boxOffice   Float? // box office collection
  status      String? // "released", "upcoming", "archived"
  rating      Float? // average rating (can be computed)

  // Relations
  reviews   Review[]
  watchlist Watchlist[]
  purchases Purchase[]
  genres    MovieGenre[]
}

//////////////////////////////////////////////////////
// REVIEW
//////////////////////////////////////////////////////

model Review {
  id      String   @id @default(uuid())
  rating  Int      @default(0)
  content String
  tags    String[]
  spoiler Boolean  @default(false)

  status   ReviewStatus @default(PENDING)
  isEdited Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  movieId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  comments Comment[]
  likes    Like[]
}

//////////////////////////////////////////////////////
// COMMENT
//////////////////////////////////////////////////////

model Comment {
  id      String @id @default(uuid())
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean @default(false)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id])

  // Optional nested replies
  parentId String?
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentToComment")
}

//////////////////////////////////////////////////////
// LIKE
//////////////////////////////////////////////////////

model Like {
  id String @id @default(uuid())

  userId   String
  reviewId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  review Review @relation(fields: [reviewId], references: [id])

  @@unique([userId, reviewId]) // one like per user
}

//////////////////////////////////////////////////////
// WATCHLIST
//////////////////////////////////////////////////////

model Watchlist {
  id String @id @default(uuid())

  userId  String
  movieId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("id")
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  stripeEventId String?       @unique // to link with Stripe events
  id            String        @id @default(uuid())
  amount        Float
  status        PaymentStatus @default(PENDING)
  provider      String

  transactionId String? @unique // from payment gateway

  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  purchaseId String?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////////
// PURCHASE / ACCESS CONTROL
//////////////////////////////////////////////////////

model Purchase {
  id String @id @default(uuid())

  accessType AccessType
  price      Float

  expiresAt DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())

  // Relations
  userId  String
  movieId String

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@index([userId, movieId])
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([movieId, genreId])
}
